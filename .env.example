# Telegram Bot Token (get from @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_WEBHOOK_SECRET=change_this_to_a_long_random_string
# Optional: Set this if running locally (e.g., using ngrok) or on VPS
# (Render sets RENDER_EXTERNAL_URL automatically, so this is not needed on Render)
# WEBHOOK_URL=https://your-domain.com

# WooCommerce API Credentials
WOOCOMMERCE_URL=yoursite.com
WOOCOMMERCE_KEY=your_consumer_key
WOOCOMMERCE_SECRET=your_consumer_secret

# AI Shopping Assistant Settings
AI_PROVIDER=anthropic      # Options: anthropic, gemini, grok, openai, openrouter, groq
AI_MODEL=claude-3-5-sonnet-20241022  # Examples: claude-3-5-sonnet-20241022, gemini-1.5-flash, grok-2-1212, gpt-4o-mini, google/gemini-2.5-flash, llama3-8b-8192

# Provider API Keys (Fill in the one matching your selected AI_PROVIDER)
ANTHROPIC_API_KEY=your_anthropic_key_here
GEMINI_API_KEY=your_gemini_key_here
GROK_API_KEY=your_grok_key_here
OPENAI_API_KEY=your_openai_key_here
OPENROUTER_API_KEY=your_openrouter_key_here
GROQ_API_KEY=your_groq_key_here

# Pathao API Credentials
PATHAO_BASE_URL=https://api-hermes.pathao.com
PATHAO_CLIENT_ID=your_pathao_client_id
PATHAO_CLIENT_SECRET=your_pathao_client_secret
PATHAO_USERNAME=your_pathao_username
PATHAO_PASSWORD=your_pathao_password

# Supabase Persistence
SUPABASE_URL=your_supabase_project_url
SUPABASE_KEY=your_supabase_anon_key
